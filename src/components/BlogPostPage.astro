---
import Layout from "../layouts/Layout.astro";
import type { Locale } from "../lib/i18n";
import { translations } from "../lib/i18n";
import type { BlogPost } from "../lib/posts";

export interface Props {
  post: BlogPost;
  locale: Locale;
}

const { post, locale } = Astro.props;
const t = translations[locale];

const title = post.title + " — Ezequiel Ranieri";
const desc = post.excerpt || post.title;
const cover = post.cover || "";
const tags = post.tags || [];
const content = post.content || "";
const date = post.date || "";
const lang = post.lang || "es";
const slug = post.slug;
const translationSlug = post.translationSlug || "";
const hasTranslation = translationSlug.length > 0;
const translationLocale: Locale = lang === "es" ? "en" : "es";
const localeToggleHref = hasTranslation
  ? "/" + translationLocale + "/blog/" + translationSlug
  : "/" + translationLocale + "/blog";
---

<Layout title={title} description={desc} locale={locale} contentLang={lang} localeToggleHref={localeToggleHref}>
  <meta property="og:title" content={title} />
  <meta property="og:description" content={desc} />
  <meta property="og:type" content="article" />
  <meta property="og:url" content={"/" + locale + "/blog/" + slug} />
  {cover && <meta property="og:image" content={cover} />}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={desc} />
  {cover && <meta name="twitter:image" content={cover} />}

  <article class="max-w-2xl mx-auto px-4 sm:px-6 pt-28 pb-24">
    <nav class="mb-12">
      <a href={"/" + locale + "/"} class="font-mono text-xs tracking-widest uppercase text-ink-dim hover:text-ink transition-colors duration-150">{t.blog.back}</a>
      {hasTranslation && <a href={"/" + translationLocale + "/blog/" + translationSlug} class="ml-4 font-mono text-xs tracking-widest uppercase text-ink-dim hover:text-ink transition-colors duration-150">{t.blog.readTranslation}</a>}
    </nav>

    <header class="mb-10">
      <div class="flex items-center gap-3 mb-4 flex-wrap">
        <time class="font-mono text-xs tracking-wider text-ink-dim">{date}</time>
        <span class="w-px h-3 bg-line shrink-0"></span>
        <span class="font-mono text-[11px] tracking-widest uppercase text-ink-dim shrink-0">{lang.toUpperCase()}</span>
        <span class="w-px h-3 bg-line shrink-0"></span>
        <div class="flex flex-wrap gap-2">
          {tags.map((tag) => <span class="px-2 py-0.5 text-[11px] font-mono tracking-wider uppercase border border-line text-ink-dim">{tag}</span>)}
        </div>
      </div>
      <h1 class="font-display text-3xl sm:text-4xl tracking-tight text-ink uppercase leading-[1.1]">{post.title}</h1>
    </header>

    {cover && cover.length > 1 && <img src={cover} alt={post.title} class="w-full border border-line mb-10" loading="eager" />}

    <div class="prose-custom" set:html={content}></div>
  </article>
</Layout>
