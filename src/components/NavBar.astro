---
import type { Locale } from "../lib/i18n";
import { translations } from "../lib/i18n";

export interface Props {
  locale: Locale;
  localeToggleHref?: string;
}

const { locale, localeToggleHref } = Astro.props;
const t = translations[locale];
const other: Locale = locale === "en" ? "es" : "en";
const toggleHref = localeToggleHref || "/" + other + "/";
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-bg/80 backdrop-blur-sm" id="navbar">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 flex items-center justify-between h-14">
    <a href={"/" + locale + "/"} class="text-ink hover:text-ink-dim transition-colors duration-150 flex items-center shrink-0">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 2304 1536" class="h-10 w-auto">
        <g transform="translate(0,1536) scale(0.1,-0.1)">
          <path id="logo-path" class="logo-path" fill="currentColor" d="M11730 12379 c-1008 -25 -2075 -230 -2880 -552 -667 -266 -1306 -670
