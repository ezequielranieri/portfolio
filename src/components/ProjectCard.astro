---
import type { Project } from "../lib/github";
import type { Locale } from "../lib/i18n";

export interface Props {
  project: Project;
  locale: Locale;
}

const { project, locale } = Astro.props;
const description = project.description[locale];
const title = project.name
  .split("-")
  .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
  .join(" ");
---

<a
  href={project.repoUrl}
  target="_blank"
  rel="noopener noreferrer"
  class="block border border-line p-5 sm:p-6 flex flex-col h-full hover:bg-bg-raised hover:-translate-y-0.5 transition duration-150 group"
>
  <div class="flex items-start justify-between gap-4 mb-3">
    <h3 class="font-display text-lg tracking-tight text-ink uppercase group-hover:text-ink-dim transition-colors duration-150">
      {title}
    </h3>
    <span class="shrink-0 font-mono text-xs tracking-wider text-ink-dim flex items-center gap-1.5">
      <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
        <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
      </svg>
      <span class="tabular-nums">{project.stars}</span>
    </span>
  </div>

  <p class="text-ink-dim text-sm leading-relaxed mb-4 flex-1">
    {description}
  </p>

  <div class="mt-auto flex flex-wrap gap-2">
    {project.stack.map((tech) => (
      <span class="px-2.5 py-1 text-xs font-mono tracking-wider uppercase border border-line text-ink-dim">
        {tech}
      </span>
    ))}
  </div>
</a>
